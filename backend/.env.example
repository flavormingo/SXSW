# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/sxsw?sslmode=require

# Auth
BETTER_AUTH_SECRET=your-256-bit-secret-here
BETTER_AUTH_URL=https://api.sxsw.pizza
MAGIC_LINK_EXPIRY_MINUTES=15

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@sxsw.pizza

# Apple Push Notifications
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=XXXXXXXXXX
APNS_BUNDLE_ID=com.madebysnacks.SXSW
APNS_KEY_PATH=./certs/AuthKey.p8
APNS_ENVIRONMENT=production

# App
PORT=3000
NODE_ENV=production
API_BASE_URL=https://api.sxsw.pizza
CORS_ORIGIN=https://sxsw.pizza

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Scraper
SXSW_SCHEDULE_BASE_URL=https://schedule.sxsw.com
SCRAPE_CRON=0 */6 * * *
SCRAPE_RATE_LIMIT_MS=1000

# Logging
LOG_LEVEL=info
